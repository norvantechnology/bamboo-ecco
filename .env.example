# =============================================================================
# Copy to .env then: pnpm setup:env
# Local: keep localhost URLs below.
# Production: set the SAME keys in Railway (API) + Vercel (storefront/admin).
# Do NOT commit real .env files — they are gitignored.
# =============================================================================

# BACKEND (Railway / apps/api)
# Railway: leave API_PORT empty or use Railway's PORT (code reads API_PORT || PORT)
MONGODB_URI=mongodb://localhost:27017/ecoo
API_PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://bambooecohub.com,https://www.bambooecohub.com,https://bamboo-ecco-storefront.vercel.app,https://bamboo-ecco-admin.vercel.app
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=2h
DEFAULT_TENANT_DOMAIN=localhost
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=bamboo-eco-hub

# FRONTEND STOREFRONT — Vercel project (apps/storefront)
# Production example:
#   NEXT_PUBLIC_API_URL=https://YOUR-API.up.railway.app
#   NEXT_PUBLIC_TENANT_DOMAIN=localhost
#   NEXT_PUBLIC_SITE_URL=https://bambooecohub.com
#   NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_TENANT_DOMAIN=localhost
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# FRONTEND ADMIN — Vercel project (apps/admin)
# Production example:
#   VITE_API_URL=https://YOUR-API.up.railway.app
#   VITE_STOREFRONT_URL=https://bambooecohub.com
VITE_API_URL=http://localhost:4000
VITE_STOREFRONT_URL=http://localhost:3000

# =============================================================================
# BACKLINK & CONTENT SYNDICATION WORKFLOW SECRETS (.github/workflows/backlink-syndication.yml)
# Add these in GitHub Repo -> Settings -> Secrets and variables -> Actions
# =============================================================================

# Dev.to: Generate API key at https://dev.to/settings/extensions -> "DEV.to API Keys"
DEVTO_KEY=

# WordPress.com: Create an app at https://developer.wordpress.com/apps/ to get Client ID & Secret, then generate User Token
WPCOM_CLIENT_ID=
WPCOM_CLIENT_SECRET=
WPCOM_TOKEN=
WPCOM_SITE_ID=bambooecohub.wordpress.com

# Blogger: Enable Blogger API v3 in Google Cloud Console (https://console.cloud.google.com/), create OAuth Credentials
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
BLOGGER_REFRESH_TOKEN=
BLOGGER_BLOG_ID=

# Tumblr: Register an application at https://www.tumblr.com/oauth/apps to get Consumer Key & Secret, then authorize token
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
TUMBLR_TOKEN=
TUMBLR_TOKEN_SECRET=
TUMBLR_BLOG_IDENTIFIER=bambooecohub

# Mastodon: Go to your Mastodon Instance Settings -> Development -> New Application to generate Access Token
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_TOKEN=

# GitHub Pages Mirror: Name of separate repository for hosting markdown mirror (e.g., owner/bambooecohub-mirror)
GH_MIRROR_REPO=

# Telegram: Create bot via @BotFather on Telegram (https://t.me/BotFather) to get Bot Token, and add bot as Admin to Channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@bambooecohub


# Unsplash (free) — sign up at https://unsplash.com/developers — 50 req/hr free
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
