# API
MONGODB_URI=mongodb://localhost:27017/ecoo
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Optional: if storefront sends an unknown host (e.g. *.vercel.app), fall back to this tenant.domain
DEFAULT_TENANT_DOMAIN=localhost

# Storefront
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Must match the tenant.domain value in MongoDB (seeded as "localhost" by default).
# On Vercel, set this to "localhost" OR add your Vercel host to tenant.domains in MongoDB.
NEXT_PUBLIC_TENANT_DOMAIN=localhost
# Google Search Console verification code (optional)
NEXT_PUBLIC_GSC_VERIFICATION=

# Payments — Razorpay (get test keys from https://dashboard.razorpay.com/app/keys)
# When both are set, checkout uses live Razorpay modal; otherwise dev mock payment is used.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary — image storage & SEO-optimized delivery (https://cloudinary.com/console)
# API uses all three; storefront uses cloud name for Next.js image loader.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=terra-living
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Admin
VITE_API_URL=http://localhost:4000
VITE_STOREFRONT_URL=http://localhost:3000
